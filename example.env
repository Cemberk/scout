# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Wiki backend — where the compile-capable knowledge store lives.
# Default: local:./context (LocalBackend, dev only).
# Prod options:
#   github:<owner>/<repo>            — WikiContext(GithubBackend(...))
#   s3:<bucket>[/<prefix>]           — WikiContext(S3Backend(...))
# ---------------------------------------------------------------------------
# SCOUT_WIKI=local:./context

# ---------------------------------------------------------------------------
# Live-read contexts — comma-separated spec strings. Empty = no contexts
# (Scout can still chat via the wiki + built-in web research).
#
# Spec syntax: <kind>[:<param>]
#   slack                  — needs SLACK_BOT_TOKEN
#   gmail / drive          — need GOOGLE_* (below)
#   local:<path>           — read-only directory
#   github:<owner>/<repo>  — cloned read-only repo
#   s3:<bucket>[/<prefix>] — S3 read-only bucket
# ---------------------------------------------------------------------------
# SCOUT_CONTEXTS=slack,gmail,drive,github:agno-agi/agno,local:./context/raw

# ---------------------------------------------------------------------------
# Web research (optional) — Parallel if set, else keyless Exa MCP fallback
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# GitHub (optional) — PAT for private repos or higher API rate limits.
# Public repos clone tokenless.
# Used by GithubContext + GithubBackend (when SCOUT_WIKI=github:...).
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Google (optional — all three required together)
#   Scout's own Google app — powers Gmail, Calendar, and Drive for Scout's
#   own account. Drive scope is managed on the Google side by sharing
#   folders with Scout's account.
#
# After setting these, run `python scripts/google_auth.py` on the host to
# create token.json. Without token.json, GmailContext / DriveContext
# health returns DISCONNECTED with a fixit hint.
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Slack (optional) — Scout's own Slack bot
#   SLACK_BOT_TOKEN (xoxb-…) is the bot token issued when you install the
#   Scout app into your workspace. Both vars are required for inbound
#   @scout mentions + Leader posting.
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-***
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Leader outbound — gating (Gmail send + Calendar write)
# ---------------------------------------------------------------------------
# By default the Leader is drafts-only: Gmail's send functions and
# Calendar's create/update/delete functions are not wired. Flip this to
# "true" to let the Leader actually send on your behalf. Slack posting
# is NOT gated by this — Slack is opt-in via SLACK_BOT_TOKEN above.
# SCOUT_ALLOW_SENDS=false

# ---------------------------------------------------------------------------
# AWS (optional) — only needed when SCOUT_WIKI=s3:... or a SCOUT_CONTEXTS
# entry is `s3:<bucket>[/<prefix>]`. All three required together.
# ---------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
