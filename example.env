# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research — `WebContextProvider` is on by default (zero config).
# Backend selection (first match wins):
#   PARALLEL_API_KEY set  →  ParallelBackend (premium research + extract)
#   EXA_API_KEY set       →  ExaBackend (Exa SDK, direct search + contents)
#   neither               →  ExaMCPBackend (keyless via Exa's public MCP)
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Slack — set both to make Scout available in Slack (see docs/SLACK_CONNECT.md)
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***)
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Runtime — `dev` enables hot reload; `prd` enables JWT-gated endpoints
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev
