# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research (optional) — Parallel if set, else keyless Exa MCP fallback
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# CodeExplorer — public repos clone tokenless; add a PAT for private repos
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Google (optional — all three required together)
#   Scout's own Google app — powers Gmail, Calendar, and Drive for Scout's
#   own account. Drive scope is managed on the Google side by sharing
#   folders with Scout's account.
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Slack (optional) — Scout's own Slack bot
#   SLACK_BOT_TOKEN (xoxb-…) is the bot token issued when you install the
#   Scout app into your workspace. Both vars are required for inbound
#   @scout mentions + Leader posting.
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=xoxb-***
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Leader outbound — gating (Gmail send + Calendar write)
# ---------------------------------------------------------------------------
# By default the Leader is drafts-only: Gmail's send functions and
# Calendar's create/update/delete functions are not wired. Flip this to
# "true" to let the Leader actually send on your behalf. Slack posting
# is NOT gated by this — Slack is opt-in via SLACK_BOT_TOKEN above.
# SCOUT_ALLOW_SENDS=false

# ---------------------------------------------------------------------------
# S3Source (optional — compile-only; all four required together)
# ---------------------------------------------------------------------------
# S3_BUCKETS=                      # e.g. acme-docs,acme-archive:reports/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
