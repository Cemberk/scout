# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research (optional) — Parallel if set, else keyless Exa MCP fallback
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# CodeExplorer — public repos clone tokenless; add a PAT for private repos
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Google (optional — all three required together)
#   Enables Gmail, Calendar, and Drive source
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=

# ---------------------------------------------------------------------------
# Slack (optional) — both required for inbound @scout + Leader posting
# ---------------------------------------------------------------------------
# SLACK_TOKEN=xoxb-***
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# S3Source (optional — compile-only; all four required together)
# ---------------------------------------------------------------------------
# S3_BUCKETS=                      # e.g. acme-docs,acme-archive:reports/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
