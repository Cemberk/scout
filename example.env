# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research — `WebContextProvider` is on by default (zero config).
# Backend selection (first match wins):
#   PARALLEL_API_KEY set  →  ParallelBackend (premium research + extract)
#   EXA_API_KEY set       →  ExaBackend (Exa SDK, direct search + contents)
#   neither               →  ExaMCPBackend (keyless via Exa's public MCP)
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# GitHub context — read-only. Uses a fine-grained PAT with Contents+Metadata
# read (and Pull Requests / Issues read if you want those surfaced).
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=ghp_***

# ---------------------------------------------------------------------------
# Filesystem context — point at a directory to expose it as a queryable
# (read-only) source. Leave unset to skip the filesystem provider.
# ---------------------------------------------------------------------------
# SCOUT_FS_ROOT=/path/to/knowledge

# ---------------------------------------------------------------------------
# MCP contexts — YAML config listing one or more MCP servers to register
# as context providers. See docs/MCP.md for the schema.
# ---------------------------------------------------------------------------
# SCOUT_MCP_CONFIG=./mcp_servers.yaml

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg

# ---------------------------------------------------------------------------
# Slack — set both to make Scout available in Slack (see docs/SLACK_CONNECT.md).
# SLACK_BOT_TOKEN alone also activates the Slack context provider (read-only
# workspace search, channel history, thread expansion).
#   SLACK_BOT_TOKEN       Bot User OAuth Token (xoxb-***)
#   SLACK_SIGNING_SECRET  Signing Secret (Basic Information → App Credentials)
# ---------------------------------------------------------------------------
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Runtime — `dev` enables hot reload; `prd` enables JWT-gated endpoints
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev
