# ===========================================================================
# Scout — Enterprise Context Agent
# ===========================================================================

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web Research (optional)
# ---------------------------------------------------------------------------
# EXA_API_KEY=***                  # Exa web search for Navigator + Linter
# PARALLEL_API_KEY=***             # Enables Researcher agent (search + extract + ingest)

# ---------------------------------------------------------------------------
# Google Integration (optional — all 3 required together)
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=***
# GOOGLE_CLIENT_SECRET=***
# GOOGLE_PROJECT_ID=***

# ---------------------------------------------------------------------------
# Slack (optional)
# ---------------------------------------------------------------------------
# SLACK_TOKEN=xoxb-***             # Slack bot token
# SLACK_SIGNING_SECRET=***         # Slack request verification
# SLACK_CHANNEL_ALLOWLIST=C123,C456  # Comma-separated channel IDs (empty = all)

# ---------------------------------------------------------------------------
# Sources — v3
# ---------------------------------------------------------------------------
# GOOGLE_DRIVE_FOLDER_IDS=foo,bar  # Comma-separated Drive folder IDs to scope GoogleDriveSource
# SCOUT_WORKSPACE_ID=default       # Workspace scoping (multi-workspace lands in Phase 4)
# SCOUT_COMPILE_MODEL=gpt-5.4      # Override the model used by the Compiler runner

# ---------------------------------------------------------------------------
# Git Sync (optional — both required together)
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=ghp_***      # GitHub personal access token for context repo
# SCOUT_REPO_URL=https://github.com/your-org/scout-context.git

# ---------------------------------------------------------------------------
# GitHubSource (optional — live-read over code repos; both required together)
# ---------------------------------------------------------------------------
# GITHUB_REPOS=acme/api,acme/web   # Comma-separated owner/repo. Enables GitHubSource.
# GITHUB_READ_TOKEN=ghp_***        # Read-only PAT, separate from GITHUB_ACCESS_TOKEN

# ---------------------------------------------------------------------------
# S3Source (optional — compile-only; all four required together)
# ---------------------------------------------------------------------------
# S3_BUCKETS=acme-docs,acme-archive:reports/  # bucket[:prefix], comma-separated
# AWS_ACCESS_KEY_ID=AKIA***
# AWS_SECRET_ACCESS_KEY=***
# AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Context & Documents
# ---------------------------------------------------------------------------
# SCOUT_CONTEXT_DIR=./context      # Context directory (default: ./context)
# SCOUT_RAW_DIR=./context/raw      # Raw intake (user-writable, compile-only)
# SCOUT_COMPILED_DIR=./context/compiled  # Compiled wiki (Obsidian-compatible vault)
# SCOUT_VOICE_DIR=./context/voice  # Voice guides
# DOCUMENTS_DIR=./documents        # Enterprise documents (default: ./documents)

# ---------------------------------------------------------------------------
# Database (defaults work out of the box with docker compose)
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev                  # dev = hot reload, prd = RBAC enabled
# AGENTOS_URL=http://127.0.0.1:8000  # Scheduler callback URL
