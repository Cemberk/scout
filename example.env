# ---------------------------------------------------------------------------
# Required — OpenAI powers every agent and embeddings
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research — `WebContextProvider` is on by default (zero config).
# Backend selection:
#   PARALLEL_API_KEY set  →  ParallelBackend (premium research + extract)
#   unset                 →  ExaMCPBackend (keyless via Exa's public MCP)
# EXA_API_KEY is optional — raises rate limits on ExaMCPBackend.
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=
# EXA_API_KEY=

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai
# DB_DRIVER=postgresql+psycopg
