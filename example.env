# ===========================================================================
# Scout — Enterprise Context Agent
# ===========================================================================
# Copy to `.env` and fill in what you need. Everything below the Required
# block is optional — each block enables one source or integration.

# ---------------------------------------------------------------------------
# Required — agents + Leader + Compiler run on GPT-5.4, and embeddings
# (text-embedding-3-small) for the Knowledge/Learnings path also use OpenAI.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-***

# ---------------------------------------------------------------------------
# Web research (optional) — Parallel is the only web-search backend
# ---------------------------------------------------------------------------
# PARALLEL_API_KEY=                # Navigator / Linter / Researcher web search + extract

# ---------------------------------------------------------------------------
# Google integration (optional — all three required together)
#   Enables: Gmail (read + draft), Calendar (read), Drive source (live-read)
# ---------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_PROJECT_ID=
# GOOGLE_DRIVE_FOLDER_IDS=         # Comma-separated Drive folder IDs

# ---------------------------------------------------------------------------
# Slack (optional) — both required for inbound @scout + Leader posting
# ---------------------------------------------------------------------------
# SLACK_TOKEN=xoxb-***
# SLACK_SIGNING_SECRET=
# SLACK_CHANNEL_ALLOWLIST=         # Comma-separated channel IDs (empty = all)

# ---------------------------------------------------------------------------
# GitHubSource (optional — live-read over code repos; both required together)
# ---------------------------------------------------------------------------
# GITHUB_REPOS=                    # Comma-separated owner/repo
# GITHUB_READ_TOKEN=               # Read-only PAT (separate from the one below)

# ---------------------------------------------------------------------------
# S3Source (optional — compile-only; all four required together)
# ---------------------------------------------------------------------------
# S3_BUCKETS=                      # e.g. acme-docs,acme-archive:reports/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ---------------------------------------------------------------------------
# Git sync for context/ (optional — both required together)
#   Scout pushes/pulls the wiki to your own repo. Durable, portable, no volumes.
# ---------------------------------------------------------------------------
# GITHUB_ACCESS_TOKEN=             # PAT with push on the context repo
# SCOUT_REPO_URL=                  # e.g. https://github.com/your-org/scout-context.git

# ---------------------------------------------------------------------------
# Scout internals (optional)
# ---------------------------------------------------------------------------
# SCOUT_WORKSPACE_ID=default       # Workspace scoping (multi-workspace lands later)
# SCOUT_API_HOST_PORT=8000         # Host port the API publishes on

# ---------------------------------------------------------------------------
# Database — defaults match docker compose
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_DATABASE=ai

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev                  # dev = hot reload
# AGENTOS_URL=http://127.0.0.1:8000 # Scheduler callback URL
